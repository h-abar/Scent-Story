# ====== قاعدة البيانات ======
# في التطوير المحلي استخدم PostgreSQL قيد التشغيل (مثلاً عبر Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scent_story?schema=public"

# ====== مصادقة لوحة الإدارة (كلمة المرور المشتركة) ======
# ضع قيمة قوية في الإنتاج
ADMIN_PASSWORD="change-me-in-production"
# سر تشفير جلسة iron-session (32 حرفًا على الأقل)
SESSION_SECRET="please-change-this-to-a-long-random-secret-value-32+chars"

# ====== الإعدادات العامة ======
# رابط الموقع الأساسي (يُستخدم لروابط الإيميل/الطباعة)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# رقم واتساب بصيغة دولية بدون + أو مسافات (مثال السعودية)
NEXT_PUBLIC_WHATSAPP_NUMBER="966500000000"

# ====== التخزين المحلي ======
# مسار مجلد الرفعات. على Railway: /data/uploads (volume مُحمّل)
UPLOAD_DIR="/data/uploads"
